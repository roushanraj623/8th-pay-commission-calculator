<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>8th Pay Commission Salary Calculator</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body class="bg-gray-50 text-gray-800 font-sans min-h-screen flex flex-col justify-between">

    <main class="max-w-2xl w-full mx-auto my-10 p-6 bg-white rounded-2xl shadow-xl border border-gray-100 flex-grow">
        
        <div class="text-center mb-8">
            <h1 class="text-3xl font-extrabold text-blue-900 mb-2">💰 8th Pay Commission Calculator</h1>
            <p class="text-gray-500 text-sm">Calculate your projected revised basic pay across different fitment factor demands.</p>
        </div>

        <div class="bg-blue-50 p-5 rounded-xl mb-8 border border-blue-100">
            <label for="basicPay" class="block text-sm font-semibold text-blue-900 mb-2">Enter Current Basic Pay (₹):</label>
            <div class="relative rounded-md shadow-sm">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <span class="text-gray-500 sm:text-sm">₹</span>
                </div>
                <input type="number" id="basicPay" value="60000" class="block w-full pl-8 pr-3 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-lg font-medium outline-none" placeholder="e.g. 60000" oninput="calculateSalary()">
            </div>
        </div>

        <div class="space-y-4">
            <h2 class="text-lg font-bold text-gray-700 mb-3">Projected Scenarios</h2>

            <div class="flex items-center justify-between p-4 bg-orange-50 border border-orange-100 rounded-xl">
                <div>
                    <h3 class="font-bold text-orange-900">Conservative Speculation</h3>
                    <p class="text-xs text-orange-700">Fitment Factor: 1.83x</p>
                </div>
                <div class="text-right">
                    <span id="resConservative" class="text-xl font-black text-orange-900">₹0.00</span>
                </div>
            </div>

            <div class="flex items-center justify-between p-4 bg-blue-50 border border-blue-100 rounded-xl">
                <div>
                    <h3 class="font-bold text-blue-900">Common Media Speculation</h3>
                    <p class="text-xs text-blue-700">Fitment Factor: 2.86x</p>
                </div>
                <div class="text-right">
                    <span id="resMedia" class="text-xl font-black text-blue-900">₹0.00</span>
                </div>
            </div>

            <div class="flex items-center justify-between p-4 bg-green-50 border border-green-100 rounded-xl">
                <div>
                    <h3 class="font-bold text-green-900">Official Union Demand (NC-JCM)</h3>
                    <p class="text-xs text-green-700">Fitment Factor: 3.833x</p>
                </div>
                <div class="text-right">
                    <span id="resUnion" class="text-xl font-black text-green-900">₹0.00</span>
                </div>
            </div>
        </div>

        <div class="mt-6 p-4 bg-gray-50 rounded-lg border border-gray-200">
            <p class="text-xs text-gray-600 leading-relaxed">
                <strong>⚠️ Note:</strong> These projections strictly estimate your revised <strong>Basic Pay</strong>. Final take-home pay structures will vary significantly once official allowances (HRA, DA, TA) are declared by the Commission.
            </p>
        </div>

        <hr class="my-8 border-gray-200">
        
        <div class="bg-gradient-to-r from-slate-50 to-slate-100 p-6 rounded-xl border border-gray-200 flex flex-col sm:flex-row items-center gap-5">
            <div class="w-20 h-20 rounded-full overflow-hidden shadow-md shrink-0 border-2 border-blue-900">
                <img src="profile.jpg" alt="Roushan RAJ" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                <div style="display:none;" class="w-full h-full bg-gradient-to-tr from-blue-700 to-indigo-900 flex items-center justify-center text-white text-xl font-bold">
                    RR
                </div>
            </div>
            <div class="text-center sm:text-left w-full">
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2">
                    <div>
                        <span class="text-xs font-bold uppercase tracking-wider text-blue-600 bg-blue-50 px-2.5 py-1 rounded-full">Founder & Developer</span>
                        <h3 class="text-xl font-bold text-slate-800 mt-2">Roushan RAJ</h3>
                        <p class="text-xs text-slate-500 font-semibold tracking-wide">BIT MESRA</p>
                    </div>
                    <div class="mt-1 sm:mt-0">
                        <a href="https://instagram.com/roushanrajj___" target="_blank" class="inline-flex items-center gap-2 bg-white hover:bg-pink-50 text-gray-700 hover:text-pink-600 border border-gray-200 rounded-full px-4 py-1.5 text-sm font-medium transition-colors shadow-xs">
                            <i class="fa-brands fa-instagram text-base text-pink-500"></i>
                            <span>@roushanrajj___</span>
                        </a>
                    </div>
                </div>
                <p class="text-sm text-slate-600 mt-3 border-t border-gray-200/60 pt-2">
                    Building intuitive digital products and calculation utilities designed to simplify complex policy and financial tracking.
                </p>
            </div>
        </div>
        </main>

    <footer class="text-center py-4 text-xs text-gray-400">
        8th Pay Commission Tracker &copy; 2026
    </footer>

    <script>
        function formatCurrency(amount) {
            return '₹' + amount.toLocaleString('en-IN', { maximumFractionDigits: 2, minimumFractionDigits: 2 });
        }

        function calculateSalary() {
            const basicPay = parseFloat(document.getElementById('basicPay').value) || 0;

            const conservative = basicPay * 1.83;
            const media = basicPay * 2.86;
            const union = basicPay * 3.833;

            document.getElementById('resConservative').innerText = formatCurrency(conservative);
            document.getElementById('resMedia').innerText = formatCurrency(media);
            document.getElementById('resUnion').innerText = formatCurrency(union);
        }

        window.onload = calculateSalary;
    </script>
</body>
</html>
